# EmailJS — usado em crons.js (lembretes de feedback/treino)
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=

# Frappe (Shapefy ERPNext) — credenciais do usuário "profissional"
FRAPPE_API_KEY=
FRAPPE_API_SECRET=

# Frappe — credenciais admin (rotas privilegiadas: criar aluno, sincronizar status)
FRAPPE_API_KEY_ADMIN=
FRAPPE_API_SECRET_ADMIN=

# Nota: MegaAPI (WhatsApp) não usa env vars — config fica no Firestore em settings/whatsapp_config
